{
  "pipeline": {
    "name": "data-pipeline-etl-cd",
    "roleArn": "arn:aws:iam::211125491569:role/data-pipeline-codepipeline-role",
    "pipelineType": "V2",
    "artifactStore": {
      "type": "S3",
      "location": "cicd-artifacts-211125491569-eu-north-1"
    },
    "stages": [
      {
        "name": "Source",
        "actions": [
          {
            "name": "GitHubSource",
            "actionTypeId": {
              "category": "Source",
              "owner": "AWS",
              "provider": "CodeStarSourceConnection",
              "version": "1"
            },
            "runOrder": 1,
            "configuration": {
              "ConnectionArn": "arn:aws:codestar-connections:eu-north-1:211125491569:connection/8340927c-1ae7-456c-a5f0-6a0adf85202b",
              "FullRepositoryId": "manangupta12/data-pipeline-cicd-demo",
              "BranchName": "main",
              "OutputArtifactFormat": "CODE_ZIP"
            },
            "outputArtifacts": [
              {
                "name": "SourceOutput"
              }
            ]
          }
        ]
      },
      {
        "name": "Build",
        "actions": [
          {
            "name": "BuildAndTest",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "runOrder": 1,
            "configuration": {
              "ProjectName": "etl-customer-build"
            },
            "inputArtifacts": [
              {
                "name": "SourceOutput"
              }
            ],
            "outputArtifacts": [
              {
                "name": "BuildOutput"
              }
            ]
          }
        ]
      },
      {
        "name": "Deploy",
        "actions": [
          {
            "name": "DeployLambda",
            "actionTypeId": {
              "category": "Deploy",
              "owner": "AWS",
              "provider": "Lambda",
              "version": "1"
            },
            "runOrder": 1,
            "configuration": {
              "FunctionName": "etl-customer-s3-to-dynamodb",
              "UserParameters": "{\"aliasName\":\"prod\"}"
            },
            "inputArtifacts": [
              {
                "name": "BuildOutput"
              }
            ]
          }
        ]
      }
    ]
  }
}
